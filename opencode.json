{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "github": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@github/mcp-server"],
      "enabled": true,
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx.cmd", "-y", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "npm run compile": "allow",
      "npm run lint": "allow",
      "npm run watch": "allow",
      "npm run check:extension": "allow",
      "npm run check:webviews": "allow",
      "npm install": "allow",
      "npx @vscode/vsce package*": "allow",
      "*": "ask"
    }
  }
}
