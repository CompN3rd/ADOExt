{
  "name": "adoext",
  "displayName": "ADOExt - Azure DevOps Integration",
  "description": "Full-featured Azure DevOps integration for VS Code: work items, pull requests, comments, and multi-account/org support.",
  "version": "1.1.1",
  "publisher": "MarcKassubeck",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "azure devops",
    "ado",
    "work items",
    "pull requests",
    "git"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CompN3rd/ADOExt.git"
  },
  "homepage": "https://github.com/CompN3rd/ADOExt",
  "bugs": {
    "url": "https://github.com/CompN3rd/ADOExt/issues"
  },
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "adoextMcpProvider",
        "label": "Azure DevOps (ADOExt)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adoext",
          "title": "Azure DevOps",
          "icon": "media/icons/ado.svg"
        }
      ]
    },
    "views": {
      "adoext": [
        {
          "id": "adoext.workItems",
          "name": "Work Items",
          "icon": "media/icons/ado.svg",
          "contextualTitle": "Azure DevOps Work Items"
        },
        {
          "id": "adoext.backlog",
          "name": "Backlog",
          "icon": "media/icons/ado.svg",
          "contextualTitle": "Azure DevOps Backlog"
        },
        {
          "id": "adoext.sprints",
          "name": "Sprints",
          "icon": "media/icons/ado.svg",
          "contextualTitle": "Azure DevOps Sprints"
        },
        {
          "id": "adoext.boards",
          "name": "Boards",
          "icon": "media/icons/ado.svg",
          "contextualTitle": "Azure DevOps Boards"
        },
        {
          "id": "adoext.pullRequests",
          "name": "Pull Requests",
          "icon": "media/icons/ado.svg",
          "contextualTitle": "Azure DevOps Pull Requests"
        }
      ]
    },
    "commands": [
      {
        "command": "adoext.signIn",
        "title": "Sign In to Azure DevOps",
        "category": "ADOExt",
        "icon": "$(sign-in)"
      },
      {
        "command": "adoext.signOut",
        "title": "Sign Out from Azure DevOps",
        "category": "ADOExt",
        "icon": "$(sign-out)"
      },
      {
        "command": "adoext.selectOrganization",
        "title": "Select Organization",
        "category": "ADOExt",
        "icon": "$(organization)"
      },
      {
        "command": "adoext.selectProject",
        "title": "Select Project",
        "category": "ADOExt",
        "icon": "$(folder)"
      },
      {
        "command": "adoext.refreshWorkItems",
        "title": "Refresh Work Items",
        "category": "ADOExt",
        "icon": "$(refresh)"
      },
      {
        "command": "adoext.selectWorkItemQuery",
        "title": "Select Work Item Query",
        "category": "ADOExt",
        "icon": "$(filter)"
      },
      {
        "command": "adoext.saveWorkItemQuery",
        "title": "Save Work Item Query Preset",
        "category": "ADOExt",
        "icon": "$(save)"
      },
      {
        "command": "adoext.refreshBacklog",
        "title": "Refresh Backlog",
        "category": "ADOExt",
        "icon": "$(refresh)"
      },
      {
        "command": "adoext.openBacklogView",
        "title": "Open Backlog in Editor",
        "category": "ADOExt",
        "icon": "$(open-preview)"
      },
      {
        "command": "adoext.refreshSprints",
        "title": "Refresh Sprints",
        "category": "ADOExt",
        "icon": "$(refresh)"
      },
      {
        "command": "adoext.openSprintView",
        "title": "Open Sprint in Editor",
        "category": "ADOExt",
        "icon": "$(open-preview)"
      },
      {
        "command": "adoext.refreshBoards",
        "title": "Refresh Boards",
        "category": "ADOExt",
        "icon": "$(refresh)"
      },
      {
        "command": "adoext.openBoardView",
        "title": "Open Board in Editor",
        "category": "ADOExt",
        "icon": "$(open-preview)"
      },
      {
        "command": "adoext.openWorkItem",
        "title": "Open Work Item in Browser",
        "category": "ADOExt",
        "icon": "$(link-external)"
      },
      {
        "command": "adoext.viewWorkItemDetails",
        "title": "View Work Item Details",
        "category": "ADOExt",
        "icon": "$(eye)"
      },
      {
        "command": "adoext.changeWorkItemState",
        "title": "Change Work Item State",
        "category": "ADOExt",
        "icon": "$(edit)"
      },
      {
        "command": "adoext.startWorkingOnWorkItem",
        "title": "Start Working",
        "category": "ADOExt",
        "icon": "$(git-branch)"
      },
      {
        "command": "adoext.openSavedQuery",
        "title": "Open Saved Query",
        "category": "ADOExt",
        "icon": "$(search)"
      },
      {
        "command": "adoext.createWorkItem",
        "title": "Create Work Item",
        "category": "ADOExt",
        "icon": "$(add)"
            },
            {
        "command": "adoext.createWorkItemFromSelection",
        "title": "Create Work Item from Selection",
        "category": "ADOExt",
        "icon": "$(add)"
      },
      {
        "command": "adoext.createWorkItemFromTodo",
        "title": "Create Work Item from TODO Comment",
        "category": "ADOExt",
        "icon": "$(tasklist)"
      },
            {
        "command": "adoext.refreshPullRequests",
        "title": "Refresh Pull Requests",
        "category": "ADOExt",
        "icon": "$(refresh)"
      },
      {
        "command": "adoext.savePullRequestQuery",
        "title": "Save Pull Request Query Preset",
        "category": "ADOExt",
        "icon": "$(save)"
            },
            {
        "command": "adoext.refreshPullRequestBucket",
        "title": "Refresh Bucket",
        "category": "ADOExt",
        "icon": "$(refresh)"
      },
      {
        "command": "adoext.openPullRequest",
        "title": "Open Pull Request in Browser",
        "category": "ADOExt",
        "icon": "$(link-external)"
      },
      {
        "command": "adoext.viewPullRequestDetails",
        "title": "View Pull Request Details",
        "category": "ADOExt",
        "icon": "$(eye)"
      },
      {
        "command": "adoext.viewPullRequestDiff",
        "title": "View Pull Request Diff",
        "category": "ADOExt",
        "icon": "$(diff)"
      },
      {
        "command": "adoext.approvePullRequest",
        "title": "Approve Pull Request",
        "category": "ADOExt",
        "icon": "$(check)"
      },
      {
        "command": "adoext.approvePullRequestWithSuggestions",
        "title": "Approve Pull Request with Suggestions",
        "category": "ADOExt",
        "icon": "$(lightbulb)"
      },
      {
        "command": "adoext.waitForPullRequestAuthor",
        "title": "Wait for Pull Request Author",
        "category": "ADOExt",
        "icon": "$(clock)"
      },
      {
        "command": "adoext.rejectPullRequest",
        "title": "Reject Pull Request",
        "category": "ADOExt",
        "icon": "$(error)"
      },
      {
        "command": "adoext.resetPullRequestVote",
        "title": "Reset Pull Request Vote",
        "category": "ADOExt",
        "icon": "$(circle-slash)"
      },
      {
        "command": "adoext.checkoutPullRequest",
        "title": "Checkout Pull Request Branch",
        "category": "ADOExt",
        "icon": "$(git-branch)"
      },
      {
        "command": "adoext.replyToComment",
        "title": "Reply to Comment",
        "category": "ADOExt",
        "icon": "$(comment)"
      },
      {
        "command": "adoext.resolveThread",
        "title": "Resolve Comment Thread",
        "category": "ADOExt",
        "icon": "$(check)"
      },
      {
        "command": "adoext.reopenThread",
        "title": "Reopen Comment Thread",
        "category": "ADOExt",
        "icon": "$(issues)"
      },
      {
        "command": "adoext.addPullRequestComment",
        "title": "Add Comment to Pull Request",
        "category": "ADOExt",
        "icon": "$(add)"
      },
      {
        "command": "adoext.prComment.create",
        "title": "Add Comment",
        "category": "ADOExt",
        "icon": "$(comment)",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "adoext.prComment.reply",
        "title": "Reply",
        "category": "ADOExt",
        "icon": "$(reply)",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "adoext.prComment.resolve",
        "title": "Resolve",
        "category": "ADOExt",
        "icon": "$(check)"
      },
      {
        "command": "adoext.prComment.reopen",
        "title": "Reopen",
        "category": "ADOExt",
        "icon": "$(issues)"
      },
      {
        "command": "adoext.getMcpServerConfig",
        "title": "Copy MCP Server Configuration",
        "category": "ADOExt"
      },
      {
        "command": "adoext.showMcpServerInfo",
        "title": "Show MCP Server Info",
        "category": "ADOExt"
      },
      {
        "command": "adoext.showOutput",
        "title": "Show Output",
        "category": "ADOExt",
        "icon": "$(output)"
      },
      {
        "command": "adoext.detectRepoContext",
        "title": "Detect Repository Context from Workspace",
        "category": "ADOExt",
        "icon": "$(search)"
      },
      {
        "command": "adoext.openPullRequestSourceBranch",
        "title": "Open Source Branch in Browser",
        "category": "ADOExt",
        "icon": "$(git-branch)"
      },
      {
        "command": "adoext.openPullRequestCommit",
        "title": "Open Head Commit in Browser",
        "category": "ADOExt",
        "icon": "$(git-commit)"
      },
      {
        "command": "adoext.openWorkItemById",
        "title": "Open Work Item in Browser",
        "category": "ADOExt",
        "icon": "$(link-external)"
      },
      {
        "command": "adoext.viewWorkItemDetailsById",
        "title": "View Work Item Details",
        "category": "ADOExt",
        "icon": "$(eye)"
      },
      {
        "command": "adoext.openPullRequestById",
        "title": "Open Pull Request in Browser",
        "category": "ADOExt",
        "icon": "$(link-external)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "adoext.refreshWorkItems",
          "when": "view == adoext.workItems",
          "group": "navigation"
        },
        {
          "command": "adoext.selectWorkItemQuery",
          "when": "view == adoext.workItems",
          "group": "navigation"
        },
        {
          "command": "adoext.openSavedQuery",
          "when": "view == adoext.workItems",
          "group": "navigation"
        },
        {
          "command": "adoext.saveWorkItemQuery",
          "when": "view == adoext.workItems",
          "group": "navigation"
        },
        {
          "command": "adoext.createWorkItem",
          "when": "view == adoext.workItems",
          "group": "navigation"
        },
        {
          "command": "adoext.openBacklogView",
          "when": "view == adoext.backlog",
          "group": "navigation"
        },
        {
          "command": "adoext.refreshBacklog",
          "when": "view == adoext.backlog",
          "group": "navigation"
        },
        {
          "command": "adoext.openSprintView",
          "when": "view == adoext.sprints",
          "group": "navigation"
        },
        {
          "command": "adoext.refreshSprints",
          "when": "view == adoext.sprints",
          "group": "navigation"
        },
        {
          "command": "adoext.openBoardView",
          "when": "view == adoext.boards",
          "group": "navigation"
        },
        {
          "command": "adoext.refreshBoards",
          "when": "view == adoext.boards",
          "group": "navigation"
        },
        {
          "command": "adoext.selectOrganization",
          "when": "view == adoext.workItems || view == adoext.backlog || view == adoext.sprints || view == adoext.boards || view == adoext.pullRequests",
          "group": "navigation"
        },
        {
          "command": "adoext.detectRepoContext",
          "when": "view == adoext.workItems || view == adoext.backlog || view == adoext.sprints || view == adoext.boards || view == adoext.pullRequests",
          "group": "navigation"
        },
        {
          "command": "adoext.signIn",
          "when": "(view == adoext.workItems || view == adoext.backlog || view == adoext.sprints || view == adoext.boards || view == adoext.pullRequests) && !adoext.isSignedIn",
          "group": "navigation"
        },
        {
          "command": "adoext.refreshPullRequests",
          "when": "view == adoext.pullRequests",
          "group": "navigation"
        },
        {
          "command": "adoext.savePullRequestQuery",
          "when": "view == adoext.pullRequests",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "adoext.refreshPullRequestBucket",
          "when": "viewItem == pullRequestBucket",
          "group": "inline"
        },
        {
          "command": "adoext.viewWorkItemDetails",
          "when": "viewItem == workItem",
          "group": "inline"
        },
        {
          "command": "adoext.openWorkItem",
          "when": "viewItem == workItem",
          "group": "navigation"
        },
        {
          "command": "adoext.changeWorkItemState",
          "when": "viewItem == workItem",
          "group": "inline"
        },
        {
          "command": "adoext.startWorkingOnWorkItem",
          "when": "viewItem == workItem",
          "group": "inline"
        },
        {
          "command": "adoext.viewPullRequestDetails",
          "when": "viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "adoext.viewPullRequestDiff",
          "when": "viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "adoext.approvePullRequest",
          "when": "viewItem == pullRequest",
          "group": "review@1"
        },
        {
          "command": "adoext.approvePullRequestWithSuggestions",
          "when": "viewItem == pullRequest",
          "group": "review@2"
        },
        {
          "command": "adoext.waitForPullRequestAuthor",
          "when": "viewItem == pullRequest",
          "group": "review@3"
        },
        {
          "command": "adoext.rejectPullRequest",
          "when": "viewItem == pullRequest",
          "group": "review@4"
        },
        {
          "command": "adoext.resetPullRequestVote",
          "when": "viewItem == pullRequest",
          "group": "review@5"
        },
        {
          "command": "adoext.checkoutPullRequest",
          "when": "viewItem == pullRequest",
          "group": "inline"
        },
        {
          "command": "adoext.openPullRequest",
          "when": "viewItem == pullRequest",
          "group": "navigation"
        },
        {
          "command": "adoext.openPullRequestSourceBranch",
          "when": "viewItem == pullRequest",
          "group": "navigation"
        },
        {
          "command": "adoext.openPullRequestCommit",
          "when": "viewItem == pullRequest",
          "group": "navigation"
        },
        {
          "command": "adoext.replyToComment",
          "when": "viewItem == prComment",
          "group": "inline"
        },
        {
          "command": "adoext.resolveThread",
          "when": "viewItem == prCommentThreadActive",
          "group": "inline"
        },
        {
          "command": "adoext.reopenThread",
          "when": "viewItem == prCommentThreadResolved",
          "group": "inline"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "adoext.prComment.create",
          "group": "inline",
          "when": "commentController == adoext.prComments && commentThreadIsEmpty"
        },
        {
          "command": "adoext.prComment.reply",
          "group": "inline",
          "when": "commentController == adoext.prComments && !commentThreadIsEmpty"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "adoext.prComment.resolve",
          "group": "inline@1",
          "when": "commentController == adoext.prComments && commentThread == prThreadActive"
        },
        {
          "command": "adoext.prComment.reopen",
          "group": "inline@1",
          "when": "commentController == adoext.prComments && commentThread == prThreadResolved"
        }
      ],
      "editor/context": [
        {
          "command": "adoext.createWorkItemFromSelection",
          "when": "editorHasSelection && adoext.isSignedIn",
          "group": "adoext@1"
        },
        {
          "command": "adoext.createWorkItemFromTodo",
          "when": "adoext.isSignedIn",
          "group": "adoext@2"
        }
      ],
      "commandPalette": [
        {
          "command": "adoext.prComment.create",
          "when": "false"
        },
        {
          "command": "adoext.prComment.reply",
          "when": "false"
        },
        {
          "command": "adoext.prComment.resolve",
          "when": "false"
        },
        {
          "command": "adoext.prComment.reopen",
          "when": "false"
        },
        {
          "command": "adoext.openWorkItemById",
          "when": "false"
        },
        {
          "command": "adoext.viewWorkItemDetailsById",
          "when": "false"
        },
        {
          "command": "adoext.openPullRequestById",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "ADOExt",
      "properties": {
        "adoext.organization": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps organization name (e.g. 'mycompany' for https://dev.azure.com/mycompany)"
        },
        "adoext.project": {
          "type": "string",
          "default": "",
          "description": "Azure DevOps project name. Kept for compatibility; use organization/project selection commands for aggregation."
        },
        "adoext.organizations": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Azure DevOps organizations selected for aggregated views."
        },
        "adoext.projectsByOrganization": {
          "type": "object",
          "default": {},
          "description": "Project selections by organization for aggregated views. Use [\"*\"] to include all projects in an organization."
        },
        "adoext.workItemQueries": {
          "type": "array",
          "default": [],
          "description": "Saved work item query definitions. When empty, ADOExt falls back to adoext.workItemQuery for compatibility.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "filter"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable identifier for the saved work item query."
              },
              "label": {
                "type": "string",
                "description": "Label shown for the saved work item query."
              },
              "filter": {
                "type": "string",
                "enum": [
                  "assigned",
                  "created",
                  "mentioned",
                  "all"
                ],
                "description": "Built-in work item filter backing this saved query."
              },
              "description": {
                "type": "string",
                "description": "Optional description for the saved work item query."
              }
            }
          }
        },
        "adoext.activeWorkItemQueryId": {
          "type": "string",
          "default": "",
          "description": "Active saved work item query ID. When empty or invalid, ADOExt falls back to the first saved query or derives one from adoext.workItemQuery."
        },
        "adoext.workItemQuery": {
          "type": "string",
          "default": "assigned",
          "enum": [
            "assigned",
            "created",
            "mentioned",
            "all"
          ],
          "enumDescriptions": [
            "Work items assigned to me",
            "Work items created by me",
            "Work items where I was mentioned",
            "All active work items"
          ],
          "description": "Legacy default work item filter. Used when adoext.workItemQueries is empty."
        },
        "adoext.pullRequestQueries": {
          "type": "array",
          "default": [],
          "description": "Saved pull request bucket definitions. Custom buckets are appended after the built-in Pull Requests buckets.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "label",
              "filter"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Stable identifier for the saved pull request query."
              },
              "label": {
                "type": "string",
                "description": "Label shown for the saved pull request query."
              },
              "filter": {
                "type": "string",
                "enum": [
                  "mine",
                  "created",
                  "assigned",
                  "all"
                ],
                "description": "Built-in pull request filter backing this saved query."
              },
              "description": {
                "type": "string",
                "description": "Optional description for the saved pull request query."
              }
            }
          }
        },
        "adoext.activePullRequestQueryId": {
          "type": "string",
          "default": "",
          "description": "Legacy active pull request query ID retained for backward compatibility with older extension versions."
        },
        "adoext.pullRequestFilter": {
          "type": "string",
          "default": "mine",
          "enum": [
            "mine",
            "created",
            "assigned",
            "all"
          ],
          "enumDescriptions": [
            "PRs I created or am reviewing",
            "PRs I created",
            "PRs assigned to me for review",
            "All active PRs"
          ],
          "description": "Legacy default pull request filter retained for backward compatibility with older extension versions."
        },
        "adoext.notifyOnNewPullRequestComments": {
          "type": "boolean",
          "default": true,
          "description": "Show a small notification when new comments appear on tracked pull requests. Disable to silence the toasts."
        },
        "adoext.notifyOnPullRequestReviewRequests": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when you are added as a reviewer on a pull request."
        },
        "adoext.notifyOnPullRequestStatusChanges": {
          "type": "boolean",
          "default": true,
          "description": "Show a notification when a reviewer votes on a pull request you created."
        },
        "adoext.pullRequestCommentPollIntervalSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 60,
          "description": "How often (in seconds) ADOExt polls tracked pull requests for notifications. Ignored when all notifications are disabled."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "1.101.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "azure-devops-node-api": "^15.1.2"
  }
}
