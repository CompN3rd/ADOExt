{
  "defaultMode": "auto",
  "mcpServers": {
    "github": {
      "command": "npx.cmd",
      "args": ["-y", "@github/mcp-server"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "command": "npx.cmd",
      "args": ["-y", "@playwright/mcp@latest"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run compile)",
      "Bash(npm run lint)",
      "Bash(npm run watch)",
      "Bash(npm run check:extension)",
      "Bash(npm run check:webviews)",
      "Bash(npm install)",
      "Bash(npx @vscode/vsce package*)"
    ]
  }
}
